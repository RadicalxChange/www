    <p class="text-size--1">
      Contact:
      <a href="mailto:jess@radicalxchange.org" class="inline-link"
        >jess@radicalxchange.org</a
      >,
      <a href="mailto:jack@radicalxchange.org" class="inline-link"
        >jack@radicalxchange.org</a
      >,
      <!-- TODO(cwnyc-contact): swap in the CWNYC contact email once provided. -->
      and
      <a href="mailto:hello@communityweeknyc.org" class="inline-link"
        >hello@communityweeknyc.org</a
      >
      <span class="text-gray">(CWNYC contact — placeholder, confirm with partner)</span>.
    </p>
    <p class="text-size--1">
      <strong>Community Week participant?</strong> RxC is offering a free
      workshop —
      <a href="mailto:jack@radicalxchange.org" class="inline-link"
        >get in touch</a
      >.
    </p>
  </section>
</div>

