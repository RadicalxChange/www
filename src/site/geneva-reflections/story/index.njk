{% set CP = genevaStory %}
<!-- prettier-ignore -->
{% set ST = CP.statements %}
<!-- prettier-ignore -->
{% set Q = CP.axes.quadrants %}

{# FEEDBACK_URL: placeholder — replace with the review form / mailto link. #}
